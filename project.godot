; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="StarPet"
run/main_scene="res://demo.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://game_manager.gd"

[display]

window/size/viewport_width=400
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[editor_plugins]



bind_mode=0
custom_bind_ip=""
port_override_enabled=false
port_override=6550


enabled=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"

[display.window]

size/mode=2
size/resizable=false
size/initial_width=360
size/initial_height=640
size/minimum_size=Vector2i(360, 640)
size/maximum_size=Vector2i(720, 1280)
stretch/mode="viewport"
stretch/aspect="expand"

[application.android]

config/display/orientation=0
